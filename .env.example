# RealtyAI — Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://realty:realty_local_dev@localhost:5432/realty_ai
DATABASE_URL_SYNC=postgresql://realty:realty_local_dev@localhost:5432/realty_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM / AI — LiteLLM Proxy
LLM_API_BASE=http://localhost:4000
LLM_API_KEY=anything
LLM_DEFAULT_MODEL=fast-model
LLM_PREMIUM_MODEL=premium-reasoning
LLM_LOCAL_MODEL=local-realty-model

# Provider API Keys (for LiteLLM to route to cloud models)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Free LLM fallback providers (OpenAI-compatible)
# OpenCode Zen (tier 0) — free, no key needed for hy3-free
LLM_API_BASE=https://opencode.ai/zen/v1
LLM_API_KEY=
LLM_DEFAULT_MODEL=hy3-free
# NVIDIA (tier 3) — free
LLM_FALLBACK3_API_BASE=https://integrate.api.nvidia.com/v1
LLM_FALLBACK3_API_KEY=
LLM_FALLBACK3_MODEL=meta/llama-3.1-8b-instruct
# Groq (tier 4) — free tier; set GROQ_API_KEY to enable
GROQ_API_KEY=
LLM_FALLBACK4_API_BASE=https://api.groq.com/openai/v1
LLM_FALLBACK4_MODEL=llama-3.3-70b-versatile

# LiteLLM
LITELLM_MASTER_KEY=sk-realty-litellm-master

# Auth
AUTH_SECRET_KEY=change-me-in-production
AUTH_ALGORITHM=HS256
AUTH_TOKEN_EXPIRE_MINUTES=1440

# API
CORS_ORIGINS=http://localhost:3000
API_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Bot Integrations
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Email Notifications (Worker)
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=athena@realty-ai.com
EMAIL_TO=

# Public URL (for webhook registration)
PUBLIC_URL=https://realty-ai-api-production.up.railway.app
